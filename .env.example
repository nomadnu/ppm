# ── 인증키·모드는 관리자 메뉴(웹 🔒)에서 입력·저장 권장 ──
# 아래 값은 초기 시드로만 쓰이며, 관리자 메뉴에서 저장하면 그 값이 우선합니다.

# (선택) 초기 조달청 인증키 — 반드시 "Decoding 키". 비워두고 관리자 메뉴에서 넣어도 됨.
SERVICE_KEY=

# 데모 모드 초기값(관리자 메뉴에서 토글 가능). 1=합성데이터, 0=실API.
DEMO_MODE=0

# (선택) 관리자 초기 비밀번호. 미지정 시 5968.
ADMIN_PASSWORD=5968

# ── Firestore 저장소 (v0.4, 필수) ──
# 배포(Render): 서비스계정 키 JSON '문자열 전체'를 FIREBASE_CREDENTIALS 에 한 줄로 넣기
# FIREBASE_CREDENTIALS={"type":"service_account", ...}
# 로컬: 키 JSON '파일 경로'를 아래에 지정 (파일은 .gitignore로 커밋 안 됨)
FIREBASE_CREDENTIALS_FILE=firebase-key.json
