# ── 인증키·모드는 이제 관리자 메뉴(웹 🔒)에서 입력·저장하는 것을 권장합니다 ──
# 아래 값은 "초기 시드"로만 쓰이며, 관리자 메뉴에서 저장하면 DB 값이 우선합니다.

# (선택) 초기 조달청 인증키 — 반드시 "Decoding 키". 비워두고 관리자 메뉴에서 넣어도 됨.
SERVICE_KEY=

# 데모 모드 초기값(관리자 메뉴에서 토글 가능). 1=합성데이터, 0=실API.
# 키가 비어 있으면 무엇이든 자동으로 데모로 동작합니다.
DEMO_MODE=1

# (선택) 관리자 초기 비밀번호. 미지정 시 5968. 웹 관리자 메뉴에서 변경 가능.
ADMIN_PASSWORD=5968

# SQLite 파일 경로
DB_PATH=ppm.db
